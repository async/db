{
  "name": "@async/db",
  "version": "0.1.0",
  "description": "The Async data workflow package for JSON fixtures, generated types, local APIs, and SQLite-backed graduation.",
  "type": "module",
  "bin": {
    "async-db": "./src/cli.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./schema": {
      "types": "./src/schema.d.ts",
      "default": "./src/schema-builders.js"
    },
    "./config": {
      "types": "./src/config.d.ts",
      "default": "./src/config-public.js"
    },
    "./client": {
      "types": "./src/index.d.ts",
      "default": "./src/client.js"
    },
    "./hono": {
      "types": "./src/hono.d.ts",
      "default": "./src/hono.js"
    },
    "./sqlite": {
      "types": "./src/sqlite.d.ts",
      "default": "./src/sqlite.js"
    },
    "./vite": {
      "types": "./src/vite.d.ts",
      "default": "./src/vite.js"
    }
  },
  "files": [
    "src/**/*.js",
    "src/**/*.d.ts",
    "!src/**/*.test.js",
    "scripts",
    "examples/*/README.md",
    "examples/*/example.json",
    "examples/*/package.json",
    "examples/*/db/**",
    "examples/*/db.config.mjs",
    "examples/*/src/**",
    "docs/**/*.md",
    "!docs/goals/**",
    "db.config.example.mjs",
    "CHANGELOG.md",
    "README.md",
    "SPEC.md"
  ],
  "scripts": {
    "check": "node ./scripts/check-syntax.js",
    "test": "node ./scripts/run-tests.js",
    "examples": "node ./scripts/serve-examples.js",
    "view:examples": "node ./scripts/serve-examples.js",
    "db": "node ./src/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
